{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://flow-powers/arch-diagram-builder/diagram.schema.json",
  "title": "Diagram IR",
  "description": "Input for scripts/diagram.mjs. The engine (engine.mjs) enforces these rules in JS (no ajv runtime dep); this file is the formal contract + editor hint. Per-type notes: workflow nodes should carry lane+phase; sequence uses actors (or node order); architecture/dataflow/lifecycle accept optional row/col grid overrides.",
  "type": "object",
  "required": ["type", "nodes"],
  "additionalProperties": true,
  "properties": {
    "type": { "enum": ["architecture", "dataflow", "lifecycle", "workflow", "sequence"] },
    "title": { "type": "string" },
    "animate": { "type": "boolean", "default": false },
    "lanes": { "type": "array", "items": { "type": "string" }, "description": "workflow swimlanes (top→bottom)" },
    "phases": { "type": "array", "description": "workflow phases (left→right columns)" },
    "actors": { "type": "array", "items": { "type": "string" }, "description": "sequence actor order (node ids)" },
    "nodes": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "description": "unique" },
          "label": { "type": "string" },
          "cat": { "enum": ["frontend", "backend", "database", "cloud", "security", "queue", "external"] },
          "row": { "type": "integer" },
          "col": { "type": "integer" },
          "lane": { "type": "string" },
          "phase": {}
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string", "description": "an existing node id" },
          "to": { "type": "string", "description": "an existing node id" },
          "label": { "type": "string" },
          "kind": { "enum": ["normal", "async", "exception", "happy"] }
        },
        "additionalProperties": true
      }
    }
  }
}
